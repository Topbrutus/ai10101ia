# Git attributes — AI10101IA

# Force LF line endings for text files
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# Markdown
*.md text eol=lf

# Shell
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
